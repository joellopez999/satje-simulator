# Configuración de Producción para SATJE
# Copia este archivo a .env.local y configura con tus valores reales

# Supabase Configuration (Producción)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima_de_produccion
SUPABASE_SERVICE_ROLE_KEY=tu_clave_de_servicio_de_produccion

# App Configuration
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app
NODE_ENV=production

# Configuración de Railway (opcional)
PORT=3000
