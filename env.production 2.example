# Configuración de Producción - SATJE Simulator
# Copia este archivo como .env.production y configura tus valores

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
NEXT_PUBLIC_APP_NAME=SATJE Simulator - Producción

# Supabase Configuration (Configurar con tus credenciales)
# NEXT_PUBLIC_SUPABASE_URL=tu_supabase_url_aqui
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# Database Configuration
# DATABASE_URL=postgresql://usuario:password@host:puerto/database

# Security
# JWT_SECRET=tu_jwt_secret_aqui
# ENCRYPTION_KEY=tu_encryption_key_aqui

# Analytics (Opcional)
# NEXT_PUBLIC_GA_ID=tu_google_analytics_id
# NEXT_PUBLIC_GTM_ID=tu_google_tag_manager_id

# Monitoring (Opcional)
# SENTRY_DSN=tu_sentry_dsn_aqui
